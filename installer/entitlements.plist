<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow Python to JIT-compile (numpy, torch, etc.) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow Python C extensions that use unsigned executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading .so/.dylib that aren't signed with the same identity
         (critical for pip-installed C extensions like numpy, torch, etc.) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Microphone access for voice-to-text (speech recognition) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Camera access for the vision tool -->
    <key>com.apple.security.device.camera</key>
    <true/>
</dict>
</plist>
